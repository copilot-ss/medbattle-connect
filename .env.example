# Copy to .env and fill in real values. Avoid localhost for Supabase URL (Expo Go).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://example.com/support

EXPO_PUBLIC_EMAIL_CONFIRM_REDIRECT=medbattle://auth/callback
EXPO_PUBLIC_EMAIL_UPDATE_REDIRECT=medbattle://auth/callback
EXPO_PUBLIC_PASSWORD_RESET_REDIRECT=medbattle://auth/callback

EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
EXPO_PUBLIC_ADMOB_BANNER_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
EXPO_PUBLIC_ADMOB_BANNER_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
