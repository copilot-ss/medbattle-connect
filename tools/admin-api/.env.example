# Copy to .env and fill values. Never commit real secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_API_TOKEN=pick-a-long-secret-token
PORT=4001
# OPTIONAL: set to 'true' to allow SQL endpoint (disabled by default)
ALLOW_SQL=false
# OPTIONAL: restrict to comma-separated allowlist of tables (default: questions,scores,users)
ALLOWED_TABLES=questions,scores,users

# Signing key for short-lived tokens (generate a long random value)
TOKEN_SIGNING_KEY=replace-with-secret-signing-key
# Default token lifetime in seconds (e.g. 300 = 5 minutes)
TOKEN_DEFAULT_EXP=300
